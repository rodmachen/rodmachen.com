---
import type { ListItem } from '../utils/posts';
import { formatDate, CATEGORY_CONFIG } from '../utils/posts';

interface Props {
  items: ListItem[];
}

const { items } = Astro.props;
---

<ul class="card-list">
  {items.map((item) => {
    const date = formatDate(item.date);
    const catConfig = item.category ? CATEGORY_CONFIG[item.category] : null;
    const accent = catConfig?.accent || '#999';
    const initial = item.title.charAt(0);
    return (
      <li>
        <a href={item.href} class="card-link" {...(item.type === 'byline' ? { target: '_blank', rel: 'noopener' } : {})}>
          {item.image ? (
            <img src={item.image} alt="" class="card-image" loading="lazy" />
          ) : (
            <div class="card-image card-placeholder" style={`background-color: ${accent}`}>
              <span class="card-initial">{initial}</span>
            </div>
          )}
          <div class="card-body">
            <h3 class="card-title">{item.title}</h3>
            {item.subtitle && <p class="card-subtitle">{item.subtitle}</p>}
            <div class="card-meta">
              <time>{date}</time>
              {item.type === 'byline' && item.publication && (
                <span class="publication">{item.publication}</span>
              )}
            </div>
            {item.tags && item.tags.length > 0 && (
              <div class="card-tags">
                {item.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      </li>
    );
  })}
</ul>

<style>
  .card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .card-link {
    display: flex;
    align-items: stretch;
    gap: 1rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card-link:hover {
    border-color: var(--color-link);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    width: 5.5rem;
    min-width: 5.5rem;
    align-self: stretch;
    border-radius: 4px;
    object-fit: cover;
    aspect-ratio: 1;
  }

  .card-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-initial {
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.85);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
    line-height: 1.3;
  }

  .card-link:hover .card-title {
    color: var(--color-link);
  }

  .card-subtitle {
    font-size: 0.8rem;
    color: var(--color-text-light);
    font-style: italic;
    margin-bottom: 0.25rem;
  }

  .card-meta {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .card-meta time {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  .publication {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.35rem;
  }

  .tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--color-text-light);
    background: var(--color-bg-muted);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }

  @media (max-width: 500px) {
    .card-image {
      width: 3.5rem;
      height: 3.5rem;
      min-width: 3.5rem;
    }

    .card-initial {
      font-size: 1.25rem;
    }

    .card-link {
      gap: 0.5rem;
      padding: 0.5rem;
    }
  }
</style>
