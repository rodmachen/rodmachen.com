---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts');

  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags || []) {
      tagSet.add(tag);
    }
  }

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}) satisfies GetStaticPaths;

const { tag } = Astro.props;
const posts = await getCollection('posts');
const filtered = posts
  .filter((p) => p.data.tags?.includes(tag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getPostSlug(id: string): string {
  return id.replace(/^\d{4}-\d{2}-\d{2}-/, '');
}

function getPostCategory(category: string | string[] | undefined): string {
  if (Array.isArray(category)) return category[0] || 'article';
  return category || 'article';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{tag} | Rod Machen</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #111;
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      padding: 3rem 2rem;
      min-height: 100vh;
    }

    .container { max-width: 640px; margin: 0 auto; }

    header { text-align: center; margin-bottom: 3rem; }

    h1 {
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 300;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .subtitle {
      color: #777;
      font-size: 0.9rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .post-list { list-style: none; margin-bottom: 3rem; }

    .post-list li {
      display: flex;
      gap: 1.25rem;
      align-items: baseline;
      padding: 0.6rem 0;
      border-bottom: 1px solid #222;
    }

    .post-list li:first-child { border-top: 1px solid #222; }

    .post-list time {
      font-size: 0.75rem;
      color: #555;
      white-space: nowrap;
      min-width: 5.5rem;
      letter-spacing: 0.02em;
    }

    .post-list a {
      color: #ccc;
      text-decoration: none;
      font-size: 0.95rem;
      transition: color 0.2s;
    }

    .post-list a:hover { color: #fff; }

    footer { text-align: center; }

    footer a {
      color: #555;
      text-decoration: none;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: color 0.2s;
      margin: 0 1rem;
    }

    footer a:hover { color: #fff; }

    @media (max-width: 500px) {
      .post-list li { flex-direction: column; gap: 0.15rem; }
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>{tag}</h1>
      <p class="subtitle">{filtered.length} post{filtered.length !== 1 ? 's' : ''}</p>
    </header>

    <ul class="post-list">
      {filtered.map((post) => {
        const slug = getPostSlug(post.id);
        const category = getPostCategory(post.data.category);
        const date = post.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <li>
            <time>{date}</time>
            <a href={`/${category}/${slug}/`}>{post.data.title || slug}</a>
          </li>
        );
      })}
    </ul>

    <footer>
      <a href="/categories/">&larr; All Categories</a>
      <a href="/blog/">&larr; Blog</a>
    </footer>
  </div>
</body>
</html>
