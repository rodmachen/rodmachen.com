---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORY_CONFIG } from '../../utils/posts';

const config = CATEGORY_CONFIG.byline;
const bylines = await getCollection('bylines');
const sorted = bylines.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`${config.label} | Edition`}>
  <header class="page-header">
    <h1 style={`color: ${config.accent}`}>{config.label}</h1>
    <p class="page-subtitle">{config.description}</p>
    <p class="page-count">{sorted.length} article{sorted.length !== 1 ? 's' : ''}</p>
  </header>

  <ul class="post-list">
    {sorted.map((byline) => {
      const date = byline.data.date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
      return (
        <li>
          <time>{date}</time>
          <div class="post-info">
            <div class="post-title-row">
              <a href={byline.data.url} target="_blank" rel="noopener">{byline.data.title}</a>
              <span class="publication">&middot; {byline.data.publication}</span>
            </div>
            {byline.data.subTitle && <div class="post-subtitle">{byline.data.subTitle}</div>}
          </div>
        </li>
      );
    })}
  </ul>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 300;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .page-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }

  .page-count {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .post-list {
    list-style: none;
    margin-bottom: 2.5rem;
  }

  .post-list li {
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-list time {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-light);
    white-space: nowrap;
    min-width: 5.5rem;
  }

  .post-list a {
    font-size: 0.95rem;
  }

  .post-info {
    flex: 1;
  }

  .post-title-row {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .publication {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .post-subtitle {
    font-size: 0.8rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  @media (max-width: 500px) {
    .post-list li {
      flex-direction: column;
      gap: 0.15rem;
    }
  }
</style>
