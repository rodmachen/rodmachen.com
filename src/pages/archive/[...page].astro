---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostSlug, getPostCategory, CATEGORY_CONFIG } from '../../utils/posts';

type ArchiveItem = {
  type: 'post' | 'byline';
  date: Date;
  title: string;
  subtitle?: string;
  href: string;
  category?: string;
  publication?: string;
  tags?: string[];
};

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection('posts');
  const bylines = await getCollection('bylines');

  const items: ArchiveItem[] = [
    ...posts.map((p) => ({
      type: 'post' as const,
      date: p.data.date,
      title: p.data.title || getPostSlug(p.id),
      subtitle: p.data.subTitle,
      href: `/${getPostCategory(p.data.category)}/${getPostSlug(p.id)}/`,
      category: getPostCategory(p.data.category),
      tags: p.data.tags || [],
    })),
    ...bylines.map((b) => ({
      type: 'byline' as const,
      date: b.data.date,
      title: b.data.title,
      subtitle: b.data.subTitle,
      href: b.data.url,
      category: 'byline',
      publication: b.data.publication,
      tags: b.data.tags || [],
    })),
  ].sort((a, b) => b.date.getTime() - a.date.getTime());

  return paginate(items, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout title={`Archive — Page ${page.currentPage} | Edition`}>
  <header class="page-header">
    <h1>Archive</h1>
    <p class="page-subtitle">Page {page.currentPage} of {page.lastPage}</p>
  </header>

  <ul class="post-list">
    {page.data.map((item) => {
      const date = item.date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
      const catConfig = item.category ? CATEGORY_CONFIG[item.category] : null;
      return (
        <li>
          <time>{date}</time>
          <div class="post-info">
            <div class="post-title-row">
              {item.type === 'byline' ? (
                <>
                  <a href={item.href} target="_blank" rel="noopener">{item.title}</a>
                  <span class="publication">&middot; {item.publication}</span>
                </>
              ) : (
                <a href={item.href}>{item.title}</a>
              )}
            </div>
            {item.subtitle && <div class="post-subtitle">{item.subtitle}</div>}
            <div class="post-meta">
              {catConfig && (
                <span class="category-badge" style={`color: ${catConfig.accent}; border-color: ${catConfig.accent}`}>
                  {catConfig.label}
                </span>
              )}
              {item.tags && item.tags.length > 0 && item.tags.map((tag) => (
                <a href={`/topics/${tag}/`} class="tag">{tag}</a>
              ))}
            </div>
          </div>
        </li>
      );
    })}
  </ul>

  <nav class="pagination">
    {page.url.prev ? <a href={page.url.prev}>&larr; Newer</a> : <span />}
    <span class="page-info">Page {page.currentPage} of {page.lastPage}</span>
    {page.url.next ? <a href={page.url.next}>Older &rarr;</a> : <span />}
  </nav>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 300;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .page-subtitle {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .post-list {
    list-style: none;
    margin-bottom: 2.5rem;
  }

  .post-list li {
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-list time {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-light);
    white-space: nowrap;
    min-width: 5.5rem;
  }

  .post-info {
    flex: 1;
  }

  .post-title-row {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .post-title-row a {
    font-size: 0.95rem;
  }

  .publication {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .post-subtitle {
    font-size: 0.8rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  .post-meta {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .category-badge {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.4rem;
    border: 1px solid;
    border-radius: 3px;
  }

  .tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-text-light);
    background: #f0f0f0;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-decoration: none;
  }

  .tag:hover {
    background: #e0e0e0;
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pagination a {
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }

  .page-info {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 500px) {
    .post-list li {
      flex-direction: column;
      gap: 0.15rem;
    }
  }
</style>
